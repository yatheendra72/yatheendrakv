---
interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
}

const { title, description, pubDate, slug, tags = [] } = Astro.props;

const formatted = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="post-card">
  <time class="date">{formatted}</time>
  <h2>
    <a href={`/blog/${slug}`}>{title}</a>
  </h2>
  {description && <p class="excerpt">{description}</p>}
  {tags.length > 0 && (
    <div class="tags">
      {tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  )}
</article>

<style>
  .post-card {
    position: relative;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    padding: 1.5rem 1.6rem;
    margin-bottom: 1.1rem;
    transition: transform var(--transition), box-shadow var(--transition),
      border-color var(--transition);
  }

  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: color-mix(in srgb, var(--accent) 45%, var(--border));
  }

  .date {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--muted);
    margin-bottom: 0.4rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  h2 {
    margin-bottom: 0.4rem;
    transition: color var(--transition);
  }

  /* whole card becomes the click target via the title link */
  h2 a::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: var(--radius);
  }

  .post-card:hover h2 a { color: var(--accent); }

  .excerpt {
    font-family: var(--serif);
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 0.8rem;
  }

  .tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
  }
</style>
