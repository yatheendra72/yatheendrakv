---
interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
}

const { title, description, pubDate, slug, tags = [] } = Astro.props;

const formatted = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="post-card">
  <time class="date">{formatted}</time>
  <h2>
    <a href={`/blog/${slug}`}>{title}</a>
  </h2>
  {description && <p class="excerpt">{description}</p>}
  {tags.length > 0 && (
    <div class="tags">
      {tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  )}
</article>

<style>
  .post-card {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
    transition: border-color var(--transition);
  }

  .post-card:last-child { border-bottom: none; }

  .date {
    display: block;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--muted);
    margin-bottom: 0.35rem;
    letter-spacing: 0.04em;
  }

  h2 { margin-bottom: 0.35rem; }

  h2 a:hover {
    color: var(--accent);
  }

  .excerpt {
    font-family: var(--serif);
    font-size: 0.92rem;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 0.65rem;
  }

  .tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.1rem 0.5rem;
    border-radius: 2px;
    opacity: 0.8;
  }
</style>
