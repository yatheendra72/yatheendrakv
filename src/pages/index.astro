---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Yatheendra KV">
  <section class="intro">
    <div class="intro-content">
      <div class="intro-text">
        <h1>Yatheendra KV</h1>
        <p class="tagline">Engineer · Reader · Thinker</p>
        <div class="bio">
          <p>
            I write about the things I spend time thinking about — software and the craft
            of building it, philosophy and the questions that don't have clean answers,
            sports, film, and occasionally, God.
          </p>
          <p>
            This is a space without an agenda. Just honest writing on whatever's on
            my mind.
          </p>
        </div>
        <div class="social-links">
          <a href="https://github.com/yatheendra72" target="_blank" rel="noopener" aria-label="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            GitHub
          </a>
          <a href="https://twitter.com/yatheendrakv" target="_blank" rel="noopener" aria-label="Twitter / X">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
            X / Twitter
          </a>
          <a href="https://linkedin.com/in/yatheendrakv" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
          <a href="mailto:yatheendra@drillbitplagiarism.com" aria-label="Email">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
            Email
          </a>
        </div>
      </div>
      <div class="avatar-wrap">
        <img src="/avatar.jpg" alt="Yatheendra KV" class="avatar" />
      </div>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="recent">
      <div class="section-header">
        <span class="section-label">Recent writing</span>
        <a href="/blog" class="see-all">All posts →</a>
      </div>
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.slug}
          tags={post.data.tags}
        />
      ))}
    </section>
  )}
</BaseLayout>

<style>
  .intro {
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .intro-content {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2.5rem;
  }

  .intro-text {
    flex: 1;
  }

  h1 {
    margin-bottom: 0.3rem;
  }

  .tagline {
    font-size: 0.9rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
    opacity: 1;
    letter-spacing: 0.02em;
  }

  .bio {
    font-family: var(--serif);
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .bio p {
    margin-bottom: 1rem;
  }

  /* AVATAR */
  .avatar-wrap {
    flex-shrink: 0;
  }

  .avatar {
    width: 130px;
    height: 130px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    border: 3px solid var(--border);
    display: block;
  }

  /* SOCIAL LINKS */
  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  .social-links a {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    border: 1px solid var(--border);
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .social-links a:hover {
    color: var(--fg);
    border-color: var(--fg);
    background: var(--card-bg);
  }

  /* RECENT WRITING */
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0.25rem;
  }

  .section-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-weight: 600;
  }

  .see-all {
    font-size: 0.8rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .see-all:hover {
    color: var(--fg);
  }

  @media (max-width: 520px) {
    .intro-content {
      flex-direction: column-reverse;
      gap: 1.5rem;
    }

    .avatar {
      width: 90px;
      height: 90px;
    }
  }
</style>
