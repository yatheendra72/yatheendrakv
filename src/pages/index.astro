---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<BaseLayout title="Yati — Watches, Tech, Philosophy & More">
  <section class="intro">
    <div class="intro-row">
      <div class="intro-text">
        <h1>Yati</h1>
        <p class="tagline">Yatheendra KV · Engineer · Watch enthusiast · Curious thinker</p>
        <div class="bio">
          <p>
            I write about the things I spend time thinking about — horology and the
            craft of watchmaking, software, philosophy, sports, film, and occasionally God.
          </p>
          <p>No agenda. Just honest writing on whatever's on my mind.</p>
        </div>
        <div class="social-links">
          <a href="https://github.com/yatheendra72" target="_blank" rel="noopener">GitHub</a>
          <a href="https://x.com/yatheendra72" target="_blank" rel="noopener">X</a>
          <a href="https://www.linkedin.com/in/yatikv" target="_blank" rel="noopener">LinkedIn</a>
          <a href="mailto:yatheendra72@gmail.com">Email</a>
        </div>
      </div>
      <div class="avatar-wrap">
        <img src="/avatar.jpg" alt="Yati" onerror="this.style.display='none'" />
      </div>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="recent">
      <div class="section-head">
        <span class="section-label">Recent writing</span>
        <a href="/blog" class="see-all">All posts →</a>
      </div>
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.slug}
          tags={post.data.tags}
        />
      ))}
    </section>
  )}
</BaseLayout>

<style>
  /* INTRO */
  .intro {
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
    transition: border-color var(--transition);
  }

  .intro-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
  }

  .intro-text { flex: 1; }

  h1 { margin-bottom: 0.25rem; }

  .tagline {
    font-size: 0.82rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
    letter-spacing: 0.01em;
  }

  .bio {
    font-family: var(--serif);
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .bio p {
    margin-bottom: 0.9rem;
    color: var(--fg);
    opacity: 0.85;
  }

  /* AVATAR */
  .avatar-wrap { flex-shrink: 0; }

  .avatar-wrap img {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    border: 2px solid var(--border);
    transition: border-color var(--transition);
  }

  /* SOCIAL */
  .social-links {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  .social-links a {
    font-size: 0.76rem;
    font-weight: 500;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    transition: color var(--transition), border-color var(--transition);
  }

  .social-links a:hover {
    color: var(--fg);
    border-color: var(--fg);
  }

  /* RECENT */
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0.25rem;
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  .see-all {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .see-all:hover { color: var(--fg); }

  @media (max-width: 500px) {
    .intro-row { flex-direction: column-reverse; gap: 1.25rem; }
    .avatar-wrap img { width: 80px; height: 80px; }
  }
</style>
