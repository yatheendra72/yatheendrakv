---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Get tag from URL query param (for filtering)
const tag = Astro.url.searchParams.get('tag') ?? '';
const posts = tag
  ? allPosts.filter(p => p.data.tags.map(t => t.toLowerCase()).includes(tag.toLowerCase()))
  : allPosts;

const allTags = [...new Set(allPosts.flatMap(p => p.data.tags))];
---

<BaseLayout
  title={tag ? `${tag.charAt(0).toUpperCase() + tag.slice(1)} — Yati` : 'All Writing — Yati'}
  description="Essays, reviews and notes on watches, tech, philosophy, sports, film, and more."
>
  <div class="page-header">
    <div class="container">
      <p class="eyebrow">The Archive</p>
      <h1>{tag ? tag.charAt(0).toUpperCase() + tag.slice(1) : 'All Writing'}</h1>
      <p class="subtitle">Essays, reviews and notes — on everything that matters.</p>
    </div>
  </div>

  <div class="filter-bar">
    <div class="container">
      <div class="filters">
        <a href="/blog" class:list={['filter', { active: !tag }]}>All</a>
        {allTags.map(t => (
          <a href={`/blog?tag=${t}`} class:list={['filter', { active: tag === t }]}>{t}</a>
        ))}
      </div>
    </div>
  </div>

  <div class="container">
    {posts.length === 0 ? (
      <p class="empty">No posts yet in this category — check back soon.</p>
    ) : (
      <div class="post-grid">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.slug}
            tags={post.data.tags}
            cover={post.data.cover}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .page-header {
    border-bottom: 1px solid var(--border);
    padding: 3.5rem 0 2.5rem;
    background: var(--card-bg);
    transition: background var(--transition), border-color var(--transition);
  }

  .eyebrow {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.6rem;
    opacity: 1;
  }

  h1 {
    font-family: var(--serif);
    font-size: 2.8rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .subtitle {
    color: var(--muted);
    font-size: 1rem;
    opacity: 1;
  }

  /* FILTER BAR */
  .filter-bar {
    border-bottom: 1px solid var(--border);
    padding: 0;
    position: sticky;
    top: 93px;
    background: var(--bg);
    z-index: 50;
    transition: background var(--transition), border-color var(--transition);
  }

  .filters {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .filters::-webkit-scrollbar { display: none; }

  .filter {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0.85rem 1.1rem;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color var(--transition), border-color var(--transition);
    flex-shrink: 0;
  }

  .filter:hover { color: var(--fg); }

  .filter.active {
    color: var(--fg);
    border-bottom-color: var(--accent);
  }

  /* GRID */
  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
    padding: 2.5rem 0 4rem;
  }

  .empty {
    text-align: center;
    color: var(--muted);
    padding: 4rem 0;
    font-style: italic;
    font-family: var(--serif);
    opacity: 1;
  }

  @media (max-width: 900px) {
    .post-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .container { padding: 0 1.25rem; }
    h1 { font-size: 2rem; }
    .post-grid { grid-template-columns: 1fr; }
    .filter-bar { top: 80px; }
  }
</style>
