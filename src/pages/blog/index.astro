---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
---

<BaseLayout
  title="Writing — Yati"
  description="Essays and notes on watches, tech, philosophy, sports, film and more."
>
  <div class="page-header">
    <h1>Writing</h1>
    <p>Essays, notes and reviews — on everything.</p>
  </div>

  <div class="filters">
    <a href="/blog" class:list={['filter', { active: true }]}>All</a>
    {allTags.map(t => (
      <a href={`/blog/tag/${t}`} class="filter">{t}</a>
    ))}
  </div>

  <div class="posts">
    {posts.length === 0
      ? <p class="empty">Nothing here yet — check back soon.</p>
      : posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.slug}
            tags={post.data.tags}
          />
        ))
    }
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
    transition: border-color var(--transition);
  }

  .page-header h1 { margin-bottom: 0.3rem; }

  .page-header p {
    font-size: 0.95rem;
    color: var(--muted);
  }

  .filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .filter {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    background: var(--card-bg);
    border: 1px solid var(--border);
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    transition: color var(--transition), border-color var(--transition),
      background var(--transition), transform var(--transition);
  }

  .filter:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 50%, var(--border));
    transform: translateY(-1px);
  }

  .filter.active {
    color: var(--on-accent);
    border-color: var(--accent);
    background: var(--accent);
  }

  .empty {
    font-family: var(--serif);
    font-style: italic;
    color: var(--muted);
    padding: 2rem 0;
  }
</style>
