---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  // Topics surfaced on the landing page — always get a page, even with no posts yet.
  const TOPICS = ['watches', 'tech', 'philosophy', 'books', 'movies', 'sports'];

  const posts = (await getCollection('blog', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  const postTags = [...new Set(posts.flatMap((p) => p.data.tags))];
  const allTags = [...new Set([...postTags, ...TOPICS])].sort();

  return allTags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter((p) => p.data.tags.includes(tag)),
      allTags,
    },
  }));
}

const { tag, posts, allTags } = Astro.props;
const heading = tag.charAt(0).toUpperCase() + tag.slice(1);
---

<BaseLayout
  title={`${heading} — Yati`}
  description={`Writing tagged "${tag}" by Yati.`}
>
  <div class="page-header">
    <h1>{heading}</h1>
    <p>Writing tagged <em>{tag}</em>.</p>
  </div>

  <div class="filters">
    <a href="/blog" class="filter">All</a>
    {allTags.map((t) => (
      <a href={`/blog/tag/${t}`} class:list={['filter', { active: t === tag }]}>{t}</a>
    ))}
  </div>

  <div class="posts">
    {posts.length === 0
      ? <p class="empty">Nothing here yet — check back soon.</p>
      : posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.slug}
            tags={post.data.tags}
          />
        ))
    }
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
    transition: border-color var(--transition);
  }

  .page-header h1 { margin-bottom: 0.3rem; }

  .page-header p {
    font-size: 0.95rem;
    color: var(--muted);
  }

  .page-header em {
    font-family: var(--serif);
    font-style: italic;
    color: var(--accent);
  }

  .filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .filter {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    background: var(--card-bg);
    border: 1px solid var(--border);
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    transition: color var(--transition), border-color var(--transition),
      background var(--transition), transform var(--transition);
  }

  .filter:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 50%, var(--border));
    transform: translateY(-1px);
  }

  .filter.active {
    color: var(--on-accent);
    border-color: var(--accent);
    background: var(--accent);
  }

  .empty {
    font-family: var(--serif);
    font-style: italic;
    color: var(--muted);
    padding: 2rem 0;
  }
</style>
