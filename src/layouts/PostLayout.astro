---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
  cover?: string;
  coverAlt?: string;
  music?: string;
}

const { title, description, pubDate, tags = [], cover, coverAlt, music } = Astro.props;

const formatted = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// `music` may be a full Spotify URL or a bare track ID.
const trackId = music
  ? (music.match(/track\/([a-zA-Z0-9]+)/)?.[1] ?? music.trim())
  : null;
---

<BaseLayout title={`${title} — Yati`} description={description}>
  <article>
    <header class="post-header">
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{formatted}</time>
        {tags.length > 0 && (
          <div class="tags">
            {tags.map((t) => (
              <a href={`/blog/tag/${t}`} class="tag">{t}</a>
            ))}
          </div>
        )}
      </div>
      <h1>{title}</h1>
      {description && <p class="description">{description}</p>}
    </header>

    {cover && (
      <figure class="cover">
        <img src={cover} alt={coverAlt ?? title} loading="eager" />
        {coverAlt && <figcaption>{coverAlt}</figcaption>}
      </figure>
    )}

    {trackId && (
      <div class="player">
        <span class="player-label">♪ Listen while you read — Cornfield Chase, Hans Zimmer</span>
        <iframe
          title="Cornfield Chase — Hans Zimmer"
          src={`https://open.spotify.com/embed/track/${trackId}?utm_source=generator&theme=0`}
          width="100%"
          height="152"
          frameborder="0"
          loading="lazy"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
        ></iframe>
      </div>
    )}

    <div class="prose">
      <slot />
    </div>

    <footer class="post-footer">
      <a href="/blog">← All writing</a>
    </footer>
  </article>
</BaseLayout>

<style>
  /* COVER */
  .cover {
    margin: 0 0 2.5rem;
  }

  .cover img {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
    border-radius: 6px;
    border: 1px solid var(--border);
    display: block;
  }

  .cover figcaption {
    margin-top: 0.6rem;
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--muted);
    text-align: center;
  }

  /* MUSIC PLAYER */
  .player {
    margin: 0 0 2.5rem;
  }

  .player-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 0.6rem;
  }

  .player iframe {
    border-radius: 12px;
    display: block;
  }

  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
    transition: border-color var(--transition);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.75rem;
    color: var(--muted);
    margin-bottom: 0.85rem;
  }

  .tags { display: flex; gap: 0.4rem; }

  .tag {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.1rem 0.5rem;
    border-radius: 2px;
    opacity: 0.85;
    transition: opacity var(--transition);
  }

  .tag:hover { opacity: 1; }

  .description {
    margin-top: 0.75rem;
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.6;
  }

  /* PROSE */
  .prose {
    font-family: var(--serif);
    font-size: 1.05rem;
    line-height: 1.9;
  }

  .prose :global(p) { margin-bottom: 1.6rem; }

  /* drop cap on the opening paragraph */
  .prose :global(p:first-of-type)::first-letter {
    float: left;
    font-family: var(--serif);
    font-weight: 600;
    font-size: 3.4rem;
    line-height: 0.74;
    margin: 0.12em 0.62rem 0 0;
    color: var(--accent);
  }

  .prose :global(h2) {
    font-size: 1.45rem;
    font-weight: 500;
    margin: 2.75rem 0 0.75rem;
    letter-spacing: -0.01em;
  }

  .prose :global(h3) {
    font-family: var(--sans);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 2.25rem 0 0.6rem;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    background: var(--accent-soft);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    padding: 1rem 1.4rem;
    margin: 2.25rem 0;
    color: var(--fg);
    font-style: italic;
    font-size: 1.1rem;
    line-height: 1.75;
  }

  .prose :global(blockquote p:last-child) { margin-bottom: 0; }

  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.6rem;
  }

  .prose :global(li) { margin-bottom: 0.4rem; }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color var(--transition);
  }

  .prose :global(a:hover) { text-decoration-color: var(--accent); }

  .prose :global(code) {
    font-family: 'SFMono-Regular', Consolas, monospace;
    font-size: 0.82em;
    background: var(--border);
    padding: 0.15em 0.4em;
    border-radius: 3px;
  }

  .prose :global(pre) {
    background: #1a1a1a;
    color: #e5e5e5;
    padding: 1.35rem;
    border-radius: 4px;
    overflow-x: auto;
    margin-bottom: 1.6rem;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .prose :global(pre code) {
    background: none; padding: 0;
    font-size: inherit; color: inherit;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 3rem 0;
  }

  /* POST FOOTER */
  .post-footer {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--muted);
    transition: border-color var(--transition);
  }

  .post-footer a:hover { color: var(--fg); }
</style>
