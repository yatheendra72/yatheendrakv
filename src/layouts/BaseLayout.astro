---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Yati — writing on watches, tech, philosophy, sports and more." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="wordmark">Yati</a>
        <div class="nav-right">
          <div class="nav-links">
            <a href="/">About</a>
            <a href="/blog">Writing</a>
          </div>
          <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-links">
        <a href="https://github.com/yatheendra72" target="_blank" rel="noopener">GitHub</a>
        <a href="https://x.com/yatheendra72" target="_blank" rel="noopener">X</a>
        <a href="https://www.linkedin.com/in/yatikv" target="_blank" rel="noopener">LinkedIn</a>
        <a href="mailto:yatheendra72@gmail.com">Email</a>
      </div>
      <p>© {new Date().getFullYear()} Yatheendra KV</p>
    </footer>

    <script>
      const toggle = document.getElementById('themeToggle');
      toggle?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg: #fafafa;
    --fg: #111111;
    --muted: #6b7280;
    --border: #e5e7eb;
    --card-bg: #ffffff;
    --accent: #b5975a;
    --max-w: 680px;
    --serif: 'Lora', Georgia, serif;
    --sans: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    --transition: 0.2s ease;
  }

  html.dark {
    --bg: #111010;
    --fg: #ede8e0;
    --muted: #9ca3af;
    --border: #1f2937;
    --card-bg: #1a1918;
  }

  html {
    font-size: 18px;
    background: var(--bg);
    color: var(--fg);
    transition: background var(--transition), color var(--transition);
  }

  body {
    font-family: var(--sans);
    line-height: 1.7;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  a {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition);
  }

  /* NAV */
  header {
    border-bottom: 1px solid var(--border);
    padding: 0 1.5rem;
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 1000;
    transition: background var(--transition), border-color var(--transition);
  }

  nav {
    max-width: var(--max-w);
    margin: 0 auto;
    height: 58px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .wordmark {
    font-family: var(--serif);
    font-size: 1.2rem;
    font-weight: 500;
    font-style: italic;
    letter-spacing: 0.01em;
    color: var(--fg);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted);
  }

  .nav-links a:hover { color: var(--fg); }

  .theme-toggle {
    background: none;
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 5px 7px;
    cursor: pointer;
    color: var(--muted);
    display: flex;
    align-items: center;
    transition: color var(--transition), border-color var(--transition);
  }

  .theme-toggle:hover { color: var(--fg); }

  .icon-moon { display: none; }
  .icon-sun  { display: block; }
  html.dark .icon-moon { display: block; }
  html.dark .icon-sun  { display: none; }

  /* MAIN */
  main {
    flex: 1;
    max-width: var(--max-w);
    width: 100%;
    margin: 0 auto;
    padding: 3.5rem 1.5rem;
  }

  /* FOOTER */
  footer {
    border-top: 1px solid var(--border);
    padding: 2rem 1.5rem;
    text-align: center;
    transition: border-color var(--transition);
  }

  .footer-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--muted);
  }

  .footer-links a:hover { color: var(--fg); }

  footer p {
    font-size: 0.75rem;
    color: var(--muted);
  }

  /* TYPOGRAPHY */
  h1 {
    font-family: var(--serif);
    font-size: 2rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  h2 {
    font-family: var(--serif);
    font-size: 1.3rem;
    font-weight: 500;
    line-height: 1.3;
  }

  @media (max-width: 600px) {
    html { font-size: 16px; }
    main { padding: 2.5rem 1.25rem; }
  }
</style>
