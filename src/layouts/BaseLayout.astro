---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Yati — writing on watches, tech, philosophy, sports and more." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <div class="header-top">
          <a href="/" class="wordmark">YATI</a>
        </div>
        <nav>
          <div class="nav-links">
            <a href="/">Home</a>
            <a href="/blog">All Writing</a>
            <a href="/blog?tag=watches">Watches</a>
            <a href="/blog?tag=tech">Tech</a>
            <a href="/blog?tag=philosophy">Philosophy</a>
            <a href="/blog?tag=sports">Sports</a>
          </div>
          <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <p class="footer-brand">YATI</p>
        <p class="footer-copy">© {new Date().getFullYear()} Yatheendra KV · Writing on watches, tech, philosophy & more</p>
        <div class="footer-links">
          <a href="https://github.com/yatheendra72" target="_blank" rel="noopener">GitHub</a>
          <a href="https://x.com/yatheendra72" target="_blank" rel="noopener">X / Twitter</a>
          <a href="https://www.linkedin.com/in/yatikv" target="_blank" rel="noopener">LinkedIn</a>
          <a href="mailto:yatheendra72@gmail.com">Email</a>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('themeToggle');
      toggle?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg: #faf9f7;
    --fg: #1a1a1a;
    --muted: #6b6b6b;
    --border: #e2ddd8;
    --card-bg: #ffffff;
    --accent: #b5975a;
    --accent-dark: #9a7d45;
    --max-w: 1200px;
    --content-w: 740px;
    --serif: 'Playfair Display', Georgia, serif;
    --sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --transition: 0.2s ease;
    --shadow: 0 2px 12px rgba(0,0,0,0.07);
    --shadow-hover: 0 8px 28px rgba(0,0,0,0.13);
  }

  html.dark {
    --bg: #111010;
    --fg: #ede8e0;
    --muted: #9a9490;
    --border: #2a2825;
    --card-bg: #1c1b19;
    --shadow: 0 2px 12px rgba(0,0,0,0.3);
    --shadow-hover: 0 8px 28px rgba(0,0,0,0.45);
  }

  html {
    font-size: 17px;
    background: var(--bg);
    color: var(--fg);
    transition: background var(--transition), color var(--transition);
  }

  body {
    font-family: var(--sans);
    line-height: 1.7;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  a {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition);
  }

  img {
    display: block;
    max-width: 100%;
  }

  /* ── HEADER ── */
  header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    transition: background var(--transition), border-color var(--transition);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .header-top {
    padding: 1.1rem 0 0.4rem;
    text-align: center;
  }

  .wordmark {
    font-family: var(--serif);
    font-size: 1.9rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--fg);
    text-decoration: none;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    border-top: 1px solid var(--border);
    padding: 0.5rem 0;
    position: relative;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-links a {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0.4rem 1rem;
    border-right: 1px solid var(--border);
    transition: color var(--transition);
  }

  .nav-links a:first-child {
    border-left: 1px solid var(--border);
  }

  .nav-links a:hover {
    color: var(--fg);
  }

  .theme-toggle {
    position: absolute;
    right: 0;
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 5px 7px;
    cursor: pointer;
    color: var(--muted);
    display: flex;
    align-items: center;
    transition: color var(--transition), border-color var(--transition);
  }

  .theme-toggle:hover { color: var(--fg); }

  .icon-moon { display: none; }
  .icon-sun  { display: block; }
  html.dark .icon-moon { display: block; }
  html.dark .icon-sun  { display: none; }

  /* ── MAIN ── */
  main {
    flex: 1;
  }

  /* ── FOOTER ── */
  footer {
    border-top: 1px solid var(--border);
    padding: 2.5rem 2rem;
    margin-top: 4rem;
    transition: border-color var(--transition);
  }

  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    text-align: center;
  }

  .footer-brand {
    font-family: var(--serif);
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    margin-bottom: 0.5rem;
    opacity: 1;
    color: var(--fg);
  }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--muted);
    margin-bottom: 1rem;
    opacity: 1;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }

  .footer-links a {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .footer-links a:hover { color: var(--fg); }

  /* ── GLOBAL TYPOGRAPHY ── */
  h1, h2, h3 {
    font-family: var(--serif);
    line-height: 1.2;
  }

  @media (max-width: 768px) {
    .header-inner { padding: 0 1rem; }
    .wordmark { font-size: 1.5rem; }
    .nav-links a { padding: 0.4rem 0.6rem; font-size: 0.62rem; }
    .nav-links a[href="/blog?tag=philosophy"],
    .nav-links a[href="/blog?tag=sports"] { display: none; }
  }
</style>
